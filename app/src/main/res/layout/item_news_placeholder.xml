<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/img_news_list_placeholder"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="@color/grey_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/tv_news_list_title_placeholder"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@color/grey_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/img_news_list_placeholder"
        app:layout_constraintTop_toTopOf="@id/img_news_list_placeholder"
        app:layout_constraintBottom_toTopOf="@id/tv_news_list_subtitle_one_placeholder"/>

    <View
        android:id="@+id/tv_news_list_subtitle_one_placeholder"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@color/grey_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/img_news_list_placeholder"
        app:layout_constraintTop_toBottomOf="@id/tv_news_list_title_placeholder"
        app:layout_constraintBottom_toTopOf="@id/tv_news_list_subtitle_two_placeholder"/>

    <View
        android:id="@+id/tv_news_list_subtitle_two_placeholder"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="80dp"
        android:background="@color/grey_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/img_news_list_placeholder"
        app:layout_constraintTop_toBottomOf="@id/tv_news_list_subtitle_one_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/img_news_list_placeholder"/>

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:background="@color/grey_placeholder"
        app:layout_constraintEnd_toEndOf="@id/tv_news_list_title_placeholder"
        app:layout_constraintStart_toStartOf="@id/tv_news_list_title_placeholder"
        app:layout_constraintTop_toBottomOf="@id/img_news_list_placeholder" />

</androidx.constraintlayout.widget.ConstraintLayout>